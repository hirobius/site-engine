# ralph/config.env — per-repo Ralph knobs (checked in; real env vars win).
# ops = PRIVATE client automation: human-in-the-loop merges, correctness over speed.
RALPH_ITER_TIMEOUT=3600
RALPH_MAX_ATTEMPTS=2
RALPH_PR_WAIT=1800
RALPH_READY_LABEL=ralph-ready
# Merge policy (enforced by ralph-gate): a PR auto-merges only when its linked
# issue was pre-tagged RALPH_AUTO_MERGE_LABEL (batch pre-approval) or the PR
# itself gets RALPH_APPROVE_LABEL. Everything else waits for a human.
RALPH_AUTO_MERGE_LABEL=ralph-auto
RALPH_APPROVE_LABEL=ralph-approved
