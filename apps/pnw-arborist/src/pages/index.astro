---
/**
 * BESPOKE editorial homepage for PNW Arborist Consulting (apps/pnw-arborist only).
 *
 * This app intentionally does NOT use the shared @hirobius/template components —
 * it's an authorized one-off "custom-component engagement" (see repo CLAUDE.md).
 * Everything visual lives in this file; nothing here touches packages/*, so the
 * fleet is unaffected. All *content* still comes from client.config.ts, so the
 * business facts stay single-sourced and the build-time acceptance gate
 * (astro.config.ts) still governs.
 *
 * Art direction: light editorial serif (Fraunces) on warm paper, deep forest-green
 * accent, oversized display type, numbered index of services, one dark full-bleed
 * statement. Motion is a dependency-free, reduced-motion-safe scroll reveal.
 */
import { client } from "../../client.config";

const b = client.business;
const c = client.copy;
const seo = client.seo;
const tel = b.phone.replace(/[^\d+]/g, "");
const thanksUrl = new URL("/thanks", seo.siteUrl).toString();

// Preview-only display-font switcher (issue: art-direction exploration). Each
// pack is a display + body pairing; the control is hidden once the site is live.
const FONT_PACKS = [
  { id: "fraunces", label: "Fraunces / Inter (default)" },
  { id: "cormorant", label: "Cormorant / EB Garamond" },
  { id: "playfair", label: "Playfair / Inter" },
  { id: "quintessential", label: "Quintessential / EB Garamond" },
  { id: "kings", label: "Kings / Inter" },
];
const isPreview =
  process.env.SITE_LIVE !== "true" && process.env.VERCEL_ENV !== "production";

// Split the hero headline so the last two words render in italic forest accent.
const words = c.heroHeadline.trim().replace(/[.]$/, "").split(" ");
const headLead = words.slice(0, -2).join(" ");
const headAccent = words.slice(-2).join(" ");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: b.name,
  telephone: b.phone,
  email: b.email,
  url: seo.siteUrl,
  areaServed: b.serviceAreas,
  address: { "@type": "PostalAddress", addressLocality: seo.city, addressRegion: seo.region },
  description: seo.description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.siteUrl} />
    {/* Preview site — keep it out of the index until go-live. */}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.siteUrl} />
    <meta property="og:image" content="/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,340;0,9..144,440;0,9..144,540;1,9..144,440;1,9..144,540&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Quintessential&family=Kings&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      // Apply the saved display-font pack before first paint (no flash).
      try {
        var fp = localStorage.getItem("pnw-fontpack");
        if (fp) document.documentElement.dataset.fontpack = fp;
      } catch (e) {}

      // Arm the scroll-reveal only when motion is welcome. No-JS / reduced-motion
      // visitors keep everything visible (the .reveal base state is visible).
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches)
        document.documentElement.classList.add("io-ready");
    </script>

    <style is:global>
      :root {
        --paper: #f2eee3;
        --paper-2: #ebe4d5;
        --ink: #1b241d;
        --muted: #5f665b;
        --forest: #2c5637;
        --forest-deep: #1d3b26;
        --line: rgba(27, 36, 29, 0.16);
        --dark: #141d17;
        --dark-paper: #ece6d7;
        --dark-muted: #9aa593;

        /* Display + body font pack (swapped live via the preview switcher). */
        --display-font: "Fraunces", Georgia, "Times New Roman", serif;
        --display-weight: 440;
        --body-font: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      html[data-fontpack="cormorant"] {
        --display-font: "Cormorant Garamond", Georgia, serif;
        --display-weight: 600;
        --body-font: "EB Garamond", Georgia, "Times New Roman", serif;
      }
      html[data-fontpack="playfair"] {
        --display-font: "Playfair Display", Georgia, serif;
        --display-weight: 500;
      }
      html[data-fontpack="quintessential"] {
        --display-font: "Quintessential", Georgia, serif;
        --display-weight: 400;
        --body-font: "EB Garamond", Georgia, "Times New Roman", serif;
      }
      html[data-fontpack="kings"] {
        --display-font: "Kings", "Brush Script MT", cursive;
        --display-weight: 400;
      }

      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--body-font);
        font-size: 17px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .wrap { width: 100%; max-width: 1140px; margin-inline: auto; padding-inline: 26px; }

      .serif {
        font-family: var(--display-font);
        font-weight: var(--display-weight);
        letter-spacing: -0.015em;
      }
      .eyebrow {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--forest);
      }
      em, .ital { font-style: italic; }

      a { color: inherit; }
      .skip {
        position: absolute; left: -999px; top: 0;
        background: var(--forest); color: var(--paper);
        padding: 10px 16px; border-radius: 4px; z-index: 60;
      }
      .skip:focus { left: 16px; top: 16px; }

      /* Buttons */
      .btn {
        display: inline-flex; align-items: center; gap: 10px;
        font-weight: 600; font-size: 15px; letter-spacing: 0.01em;
        padding: 15px 26px; border-radius: 2px; text-decoration: none;
        transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
      }
      .btn-primary { background: var(--forest); color: var(--paper); }
      .btn-primary:hover { background: var(--forest-deep); transform: translateY(-2px); }
      .btn-ghost { color: var(--ink); border-bottom: 1px solid var(--line); border-radius: 0; padding: 6px 2px; }
      .btn-ghost:hover { border-color: var(--forest); color: var(--forest); }

      /* Header */
      header.site {
        position: sticky; top: 0; z-index: 40;
        background: color-mix(in srgb, var(--paper) 86%, transparent);
        backdrop-filter: saturate(1.1) blur(8px);
        border-bottom: 1px solid var(--line);
      }
      header.site .row {
        display: flex; align-items: center; justify-content: space-between;
        height: 68px;
      }
      .wordmark { font-weight: 600; letter-spacing: 0.28em; font-size: 14px; text-transform: uppercase; text-decoration: none; }
      .wordmark span { color: var(--forest); }
      .header-cta { font-weight: 600; font-size: 14px; letter-spacing: 0.02em; text-decoration: none; }
      .header-cta:hover { color: var(--forest); }
      @media (max-width: 620px) { .header-cta { display: none; } }

      /* Hero */
      .hero { padding: clamp(56px, 12vw, 128px) 0 clamp(40px, 7vw, 76px); }
      .hero h1 {
        margin: 22px 0 0; line-height: 0.98;
        font-size: clamp(2.85rem, 10.5vw, 6.6rem);
        font-weight: var(--display-weight); letter-spacing: -0.025em; max-width: 15ch;
      }
      .hero h1 .accent { color: var(--forest); font-style: italic; }
      .hero p.sub {
        margin: 30px 0 0; max-width: 46ch; font-size: clamp(1.05rem, 2.4vw, 1.3rem);
        color: var(--muted); line-height: 1.55;
      }
      .hero .cta { margin-top: 40px; display: flex; align-items: center; gap: 26px; flex-wrap: wrap; }
      .rule-drop { width: 1px; height: 88px; margin: 54px 0 0; background: linear-gradient(var(--forest), transparent); }

      /* Section scaffolding */
      section { padding: clamp(56px, 9vw, 104px) 0; border-top: 1px solid var(--line); }
      .sec-label { display: flex; align-items: baseline; gap: 14px; margin-bottom: 46px; }
      .sec-label .n { font-size: 12px; font-weight: 600; letter-spacing: 0.2em; color: var(--muted); }
      .sec-label h2 { margin: 0; font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: var(--display-weight); letter-spacing: -0.02em; }

      /* Statement / about */
      .statement { font-size: clamp(1.6rem, 4.6vw, 2.9rem); line-height: 1.22; font-weight: 340; max-width: 24ch; letter-spacing: -0.02em; }
      .statement .accent { color: var(--forest); font-style: italic; }
      .lede { margin-top: 30px; max-width: 58ch; color: var(--muted); font-size: 1.08rem; }

      /* Services — numbered editorial index */
      .index { border-top: 1px solid var(--line); }
      .index .item {
        display: grid; grid-template-columns: 64px 1fr; gap: 8px 26px;
        padding: 30px 8px; border-bottom: 1px solid var(--line);
        transition: background 0.3s ease, padding-left 0.3s ease;
      }
      .index .item:hover { background: var(--paper-2); padding-left: 18px; }
      .index .num { font-size: 13px; font-weight: 600; letter-spacing: 0.12em; color: var(--forest); padding-top: 10px; }
      .index .item h3 { grid-column: 2; margin: 0; font-size: clamp(1.5rem, 4.4vw, 2.35rem); font-weight: var(--display-weight); letter-spacing: -0.02em; }
      .index .item p { grid-column: 2; margin: 12px 0 0; color: var(--muted); max-width: 60ch; }
      @media (max-width: 560px) {
        .index .item { grid-template-columns: 1fr; gap: 6px; }
        .index .num { padding-top: 0; }
        .index .item h3, .index .item p { grid-column: 1; }
      }

      /* Dark full-bleed statement */
      .dark { background: var(--dark); color: var(--dark-paper); border-top: none; }
      .dark .kicker { color: var(--dark-muted); }
      .dark .big { font-size: clamp(1.7rem, 5vw, 3rem); line-height: 1.2; font-weight: 340; max-width: 20ch; margin: 18px 0 0; letter-spacing: -0.02em; }
      .dark .big .accent { color: #8fbf9c; font-style: italic; }
      .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 58px; border-top: 1px solid rgba(236, 230, 215, 0.16); padding-top: 40px; }
      .stats .k { font-family: var(--display-font); font-size: clamp(2.2rem, 6vw, 3.4rem); line-height: 1; color: var(--dark-paper); }
      .stats .l { margin-top: 12px; font-size: 13px; letter-spacing: 0.06em; color: var(--dark-muted); text-transform: uppercase; }
      @media (max-width: 560px) { .stats { grid-template-columns: 1fr; gap: 26px; text-align: left; } }

      /* Service area */
      .areas { display: grid; grid-template-columns: 1.1fr 1fr; gap: 44px; align-items: center; }
      .areas .list { font-family: var(--display-font); font-size: clamp(1.8rem, 5vw, 2.9rem); line-height: 1.3; letter-spacing: -0.02em; }
      .areas .list span { color: var(--muted); }
      .map { border: 1px solid var(--line); border-radius: 4px; overflow: hidden; aspect-ratio: 4 / 3; background: var(--paper-2); }
      .map iframe { width: 100%; height: 100%; border: 0; display: block; filter: grayscale(0.35) contrast(1.02); }
      @media (max-width: 760px) { .areas { grid-template-columns: 1fr; gap: 30px; } }

      /* Contact */
      .contact { display: grid; grid-template-columns: 1fr 1fr; gap: 54px; }
      .contact .lead-serif { font-family: var(--display-font); font-size: clamp(2rem, 6vw, 3.2rem); line-height: 1.08; letter-spacing: -0.02em; margin: 14px 0 0; }
      form.quote { display: grid; gap: 20px; }
      .field label { display: block; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
      .field input, .field textarea {
        width: 100%; background: transparent; border: 0; border-bottom: 1px solid var(--line);
        padding: 10px 2px; font: inherit; color: var(--ink); border-radius: 0;
      }
      .field input:focus, .field textarea:focus { outline: none; border-color: var(--forest); }
      .field textarea { resize: vertical; min-height: 96px; }
      .hp { position: absolute; left: -9999px; opacity: 0; }
      .contact aside dl { margin: 0; display: grid; gap: 20px; }
      .contact aside dt { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px; }
      .contact aside dd { margin: 0; font-size: 1.15rem; }
      .contact aside a { text-decoration: none; }
      .contact aside a:hover { color: var(--forest); }
      @media (max-width: 760px) { .contact { grid-template-columns: 1fr; gap: 34px; } }

      /* Footer */
      footer.site { border-top: 1px solid var(--line); padding: 54px 0; }
      footer.site .row { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; align-items: flex-end; }
      footer.site .fm { font-weight: 600; letter-spacing: 0.28em; font-size: 14px; text-transform: uppercase; }
      footer.site .fm span { color: var(--forest); }
      footer.site small { color: var(--muted); font-size: 13px; line-height: 1.7; display: block; }

      /* Preview-only display-font switcher */
      .fontswitch {
        position: fixed; left: 16px; bottom: 16px; z-index: 70;
        display: flex; align-items: center; gap: 10px;
        background: var(--ink); color: var(--paper);
        padding: 9px 14px; border-radius: 999px;
        box-shadow: 0 8px 26px rgba(0, 0, 0, 0.22);
        font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
      }
      .fontswitch label { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(242, 238, 227, 0.6); }
      .fontswitch select {
        appearance: none; -webkit-appearance: none;
        background: transparent; color: var(--paper); border: 0;
        font: inherit; font-size: 13px; font-weight: 600; cursor: pointer; padding-right: 2px;
      }
      .fontswitch select option { color: #111; }
      @media (max-width: 560px) { .fontswitch label { display: none; } }
      @media print { .fontswitch { display: none; } }

      /* Reveal-on-scroll (armed only when html.io-ready) */
      .reveal { opacity: 1; transform: none; }
      html.io-ready .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.7s ease, transform 0.7s ease; }
      html.io-ready .reveal.in { opacity: 1; transform: none; }
    </style>
  </head>

  <body>
    <a class="skip" href="#main">Skip to main content</a>

    <header class="site">
      <div class="wrap row">
        <a class="wordmark" href="#top">PNW <span>Arborist</span></a>
        <a class="header-cta" href={`tel:${tel}`}>{b.phone}</a>
      </div>
    </header>

    <main id="main">
      <!-- HERO -->
      <div id="top" class="hero">
        <div class="wrap">
          <p class="eyebrow reveal">Certified Arborists · {seo.city}, {seo.region}</p>
          <h1 class="serif reveal">
            {headLead} <span class="accent">{headAccent}</span>
          </h1>
          <p class="sub reveal">{c.heroSub}</p>
          <div class="cta reveal">
            <a class="btn btn-primary" href="#contact">{c.ctaLabel}</a>
            <a class="btn btn-ghost" href={`tel:${tel}`}>Call {b.phone}</a>
          </div>
          <div class="rule-drop" aria-hidden="true"></div>
        </div>
      </div>

      <!-- ABOUT / STATEMENT -->
      <section aria-label="About">
        <div class="wrap">
          <p class="statement serif reveal">
            Careful, certified tree care for <span class="accent">{seo.city} homeowners.</span>
          </p>
          <p class="lede reveal">{c.about}</p>
        </div>
      </section>

      <!-- SERVICES — numbered index -->
      <section aria-label="Services">
        <div class="wrap">
          <div class="sec-label reveal">
            <span class="n">/ SERVICES</span>
            <h2 class="serif">What we do</h2>
          </div>
          <div class="index">
            {
              client.services.map((s, i) => (
                <div class="item reveal">
                  <div class="num">{String(i + 1).padStart(2, "0")}</div>
                  <h3 class="serif">{s.title}</h3>
                  <p>{s.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- DARK STATEMENT -->
      <section class="dark" aria-label="Why us">
        <div class="wrap">
          <p class="eyebrow kicker reveal">Trusted locally</p>
          <p class="big serif reveal">
            A reputation built one careful job at a time — <span class="accent">and it shows.</span>
          </p>
          <div class="stats">
            <div class="reveal"><div class="k">4.9★</div><div class="l">Google rating</div></div>
            <div class="reveal"><div class="k">200+</div><div class="l">Five-star reviews</div></div>
            <div class="reveal"><div class="k">Insured</div><div class="l">Free estimates</div></div>
          </div>
        </div>
      </section>

      <!-- SERVICE AREA -->
      <section aria-label="Service area">
        <div class="wrap">
          <div class="sec-label reveal">
            <span class="n">/ SERVICE AREA</span>
            <h2 class="serif">Where we work</h2>
          </div>
          <div class="areas">
            <div class="list reveal">
              {b.serviceAreas.map((a, i) => (
                <>{i > 0 && <span> · </span>}{a}</>
              ))}
              <span> — and the surrounding Thurston County area.</span>
            </div>
            <div class="map reveal">
              <iframe
                title={`Map of ${client.map.embedQuery}`}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                src={`https://www.google.com/maps?q=${encodeURIComponent(client.map.embedQuery ?? `${seo.city}, ${seo.region}`)}&output=embed`}
              ></iframe>
            </div>
          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <section id="contact" aria-label="Contact">
        <div class="wrap">
          <div class="contact">
            <div>
              <p class="eyebrow reveal">/ Get in touch</p>
              <p class="lead-serif reveal">Request a free quote.</p>
              <form class="quote reveal" action="https://api.web3forms.com/submit" method="POST">
                <input type="hidden" name="access_key" value={client.form.accessKey} />
                <input type="hidden" name="subject" value={`New quote request — ${b.name}`} />
                <input type="hidden" name="from_name" value={b.name} />
                <input type="hidden" name="redirect" value={thanksUrl} />
                <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
                <div class="field">
                  <label for="name">Name</label>
                  <input id="name" name="name" type="text" required autocomplete="name" />
                </div>
                <div class="field">
                  <label for="email">Email</label>
                  <input id="email" name="email" type="email" required autocomplete="email" />
                </div>
                <div class="field">
                  <label for="phone">Phone</label>
                  <input id="phone" name="phone" type="tel" autocomplete="tel" />
                </div>
                <div class="field">
                  <label for="message">What do you need?</label>
                  <textarea id="message" name="message" placeholder="Tree removal, pruning, a health assessment…"></textarea>
                </div>
                <button class="btn btn-primary" type="submit">{c.ctaLabel}</button>
              </form>
            </div>
            <aside class="reveal">
              <dl>
                <div><dt>Call</dt><dd><a href={`tel:${tel}`}>{b.phone}</a></dd></div>
                <div><dt>Email</dt><dd><a href={`mailto:${b.email}`}>{b.email}</a></dd></div>
                <div><dt>Hours</dt><dd>{b.hours.map((h) => `${h.days}: ${h.hours}`).join(" · ")}</dd></div>
                <div><dt>Serving</dt><dd>{b.serviceAreas.join(", ")}</dd></div>
              </dl>
            </aside>
          </div>
        </div>
      </section>
    </main>

    <footer class="site">
      <div class="wrap row">
        <div>
          <div class="fm">PNW <span>Arborist</span></div>
          <small>{b.name} · {seo.city}, {seo.region}</small>
        </div>
        <small>
          <a href={`tel:${tel}`} style="text-decoration:none">{b.phone}</a> ·
          <a href={`mailto:${b.email}`} style="text-decoration:none">{b.email}</a><br />
          Fully insured · Free estimates
        </small>
      </div>
    </footer>

    {
      isPreview && (
        <div class="fontswitch" role="group" aria-label="Preview: switch display font pack">
          <label for="fontpack">Display font</label>
          <select id="fontpack">
            {FONT_PACKS.map((p) => (
              <option value={p.id}>{p.label}</option>
            ))}
          </select>
        </div>
      )
    }

    <script is:inline>
      // Wire the preview font switcher: reflect current pack + persist changes.
      (function () {
        var sel = document.getElementById("fontpack");
        if (!sel) return;
        sel.value = document.documentElement.dataset.fontpack || "fraunces";
        sel.addEventListener("change", function () {
          document.documentElement.dataset.fontpack = sel.value;
          try {
            localStorage.setItem("pnw-fontpack", sel.value);
          } catch (e) {}
        });
      })();
    </script>

    <script is:inline>
      // Dependency-free scroll reveal. Only runs when armed (html.io-ready);
      // otherwise every .reveal stays in its visible base state.
      if (document.documentElement.classList.contains("io-ready")) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );
        for (const el of document.querySelectorAll(".reveal")) io.observe(el);
      }
    </script>
  </body>
</html>
