---
/**
 * V2 — the "Modern" design variant for PNW Arborist (route: /v2).
 *
 * A deliberately DIFFERENT design from V1 (index.astro): card-based services with
 * Lucide icons, centered section headers, a full-bleed parallax hero + stat band,
 * a "how it works" step row, a dark-green footer, and a cooler white + pine +
 * gold palette with a modern sans (Satoshi/Inter) type system. Same content
 * (client.config.ts), same preview gate + font explorer, toggled from V1 via the
 * shared PreviewControls. V1 is untouched.
 */
import { existsSync } from "node:fs";
import { join } from "node:path";
import { client } from "../../client.config";
import Icon from "../components/Icon.astro";
import PreviewControls from "../components/PreviewControls.astro";

const b = client.business;
const c = client.copy;
const seo = client.seo;
const tel = b.phone.replace(/[^\d+]/g, "");
const thanksUrl = new URL("/thanks", seo.siteUrl).toString();
const googleUrl =
  "https://www.google.com/maps/place/PNW+Arborist+Consulting+Inc/@47.039404499999996,-122.962087,14z/data=!4m8!1m2!2m1!1sPNW+Arborist+Consulting+Inc!3m4!1s0x5491753684d57163:0x9f678c481890c294!8m2!3d47.039404499999996!4d-122.962087";

const imgAt = (p: string): string | null =>
  existsSync(join(process.cwd(), "public", p)) ? `/${p}` : null;
const heroImg = imgAt("photos/v2-hero.jpg");
const bandImg = imgAt("photos/canopy.jpg");

const SERVICE_ICONS = ["axe", "scissors", "stethoscope"] as const;
const FEATURES = [
  { icon: "badge-check", title: "Local & experienced", text: "Olympia-based arborists who know Thurston County trees and soils." },
  { icon: "clock", title: "Fast scheduling", text: "Quick, honest quotes and prompt, reliable appointments." },
  { icon: "leaf", title: "Careful & clean", text: "We protect your property and leave the site tidy — every visit." },
  { icon: "star", title: "4.9-star rated", text: "Trusted across 200+ Google reviews from local homeowners." },
] as const;
const STEPS = [
  { icon: "phone-call", title: "Request a quote", text: "Call or send the form — tell us what your trees need." },
  { icon: "calendar-check", title: "We assess & schedule", text: "A certified arborist evaluates the work and sets a time." },
  { icon: "tree-pine", title: "Careful work, clean site", text: "We do the job safely and leave your yard spotless." },
] as const;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: b.name,
  telephone: b.phone,
  email: b.email,
  url: seo.siteUrl,
  areaServed: b.serviceAreas,
  address: { "@type": "PostalAddress", addressLocality: seo.city, addressRegion: seo.region },
  description: seo.description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.siteUrl} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content="/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bilbo&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Dr+Sugiyama&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Elms+Sans:wght@400;500;600;700&family=Felipa&family=Fraunces:ital,opsz,wght@0,9..144,340;0,9..144,440;0,9..144,540;1,9..144,440;1,9..144,540&family=Inter:wght@400;500;600;700&family=Kings&family=Molle:ital@1&family=Mr+Dafoe&family=Mrs+Sheppards&family=Niconne&family=Norican&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,500&family=Quintessential&family=Smooch&display=swap"
      rel="stylesheet"
    />
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap" rel="stylesheet" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      try {
        var d = localStorage.getItem("pnw-arborist-display");
        if (d) document.documentElement.dataset.display = d;
        var bd = localStorage.getItem("pnw-arborist-body");
        if (bd) document.documentElement.dataset.body = bd;
      } catch (e) {}
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches)
        document.documentElement.classList.add("io-ready");
    </script>

    <style is:global>
      :root {
        --bg: #f5f7f3;
        --surface: #ffffff;
        --ink: #15241b;
        --muted: #5a6960;
        --line: #e2e8df;
        --green: #1f5236;
        --green-d: #163a27;
        --tint: #e9f1e9;
        --gold: #bf8730;
        --dark: #12251a;
        --dark-fg: #e9f0e7;
        --dark-muted: #9db0a2;

        --display-font: "Satoshi", ui-sans-serif, system-ui, sans-serif;
        --display-weight: 700;
        --body-font: "Inter", ui-sans-serif, system-ui, sans-serif;

        --fs-eyebrow: 12px;
        --fs-body: 1.0625rem;
        --fs-lede: clamp(1.15rem, 2vw, 1.35rem);
        --fs-h2: clamp(1.9rem, 4.6vw, 2.9rem);
        --fs-hero: clamp(2.5rem, 7vw, 4.4rem);
        --fs-stat: clamp(2.4rem, 6vw, 3.5rem);
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
      body { margin: 0; background: var(--bg); color: var(--ink); font-family: var(--body-font); font-size: var(--fs-body); line-height: 1.6; -webkit-font-smoothing: antialiased; }
      .wrap { width: 100%; max-width: 1160px; margin-inline: auto; padding-inline: 24px; }
      .display { font-family: var(--display-font); font-weight: var(--display-weight); letter-spacing: -0.02em; }
      .eyebrow { font-size: var(--fs-eyebrow); font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--green); }
      a { color: inherit; }
      .skip { position: absolute; left: -999px; }
      .skip:focus { left: 16px; top: 16px; background: var(--green); color: #fff; padding: 10px 16px; border-radius: 6px; z-index: 90; }

      .btn { display: inline-flex; align-items: center; gap: 9px; font-weight: 600; font-size: 15px; padding: 15px 26px; border-radius: 10px; text-decoration: none; cursor: pointer; border: 0; transition: transform 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s; }
      .btn svg { width: 18px; height: 18px; }
      .btn-primary { background: var(--green); color: #fff; box-shadow: 0 6px 18px rgba(31, 82, 54, 0.28); }
      .btn-primary:hover { background: var(--green-d); transform: translateY(-2px); }
      .btn-gold { background: var(--gold); color: #1c1406; box-shadow: 0 6px 18px rgba(191, 135, 48, 0.3); }
      .btn-gold:hover { transform: translateY(-2px); }
      .btn-ghost { background: transparent; color: #fff; border: 1px solid rgba(255, 255, 255, 0.5); }
      .btn-ghost:hover { background: rgba(255, 255, 255, 0.12); }
      .btn-outline { background: var(--surface); color: var(--ink); border: 1px solid var(--line); }
      .btn-outline:hover { border-color: var(--green); color: var(--green); }

      /* Header */
      header.site { position: sticky; top: 0; z-index: 40; background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
      header.site .row { display: flex; align-items: center; justify-content: space-between; height: 70px; }
      .wordmark { font-family: var(--display-font); font-weight: 700; letter-spacing: 0.02em; font-size: 20px; text-decoration: none; }
      .wordmark span { color: var(--green); }
      .head-cta { padding: 11px 20px; font-size: 14px; }
      @media (max-width: 560px) { .head-cta { display: none; } }

      /* Hero — full-bleed parallax, centered */
      .hero { position: relative; overflow: hidden; background: linear-gradient(160deg, var(--green-d), var(--dark)); color: #fff; text-align: center; }
      .hero .px-layer { position: absolute; inset: -12% 0; background-size: cover; background-position: center; will-change: transform; }
      .hero .veil { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(18,37,26,0.62), rgba(18,37,26,0.82)); }
      .hero .inner { position: relative; max-width: 900px; margin-inline: auto; padding: clamp(90px, 16vw, 170px) 24px clamp(70px, 12vw, 130px); }
      .hero .eyebrow { color: #b9d4bf; }
      .hero h1 { margin: 20px 0 0; font-size: var(--fs-hero); line-height: 1.04; }
      .hero p.sub { margin: 22px auto 0; max-width: 42ch; font-size: var(--fs-lede); color: rgba(255, 255, 255, 0.86); }
      .hero .cta { margin-top: 34px; display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
      .hero .trust { margin-top: 40px; display: flex; gap: 22px 30px; justify-content: center; flex-wrap: wrap; color: rgba(255,255,255,0.9); font-size: 14px; }
      .hero .trust b { color: #fff; }
      .hero .trust span { display: inline-flex; align-items: center; gap: 8px; }
      .hero .trust svg { width: 17px; height: 17px; color: var(--gold); }

      section { padding: clamp(64px, 9vw, 110px) 0; }
      .head-center { text-align: center; max-width: 60ch; margin: 0 auto clamp(40px, 6vw, 64px); }
      .head-center h2 { margin: 14px 0 0; font-size: var(--fs-h2); }
      .head-center p { margin: 16px auto 0; color: var(--muted); font-size: var(--fs-lede); max-width: 52ch; }

      /* Services — card grid */
      .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
      @media (max-width: 860px) { .cards { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 560px) { .cards { grid-template-columns: 1fr; } }
      .card { background: var(--surface); border: 1px solid var(--line); border-radius: 18px; padding: 30px; transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s; }
      .card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(21, 36, 27, 0.1); border-color: #cfe0cf; }
      .card .ic { width: 54px; height: 54px; border-radius: 14px; background: var(--tint); color: var(--green); display: grid; place-items: center; margin-bottom: 20px; }
      .card .ic svg { width: 26px; height: 26px; }
      .card h3 { margin: 0 0 10px; font-family: var(--display-font); font-weight: 700; font-size: 1.32rem; letter-spacing: -0.01em; }
      .card p { margin: 0; color: var(--muted); }

      /* Features */
      .features { background: var(--tint); }
      .feat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 26px; }
      @media (max-width: 860px) { .feat-grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 480px) { .feat-grid { grid-template-columns: 1fr; } }
      .feat { text-align: center; }
      .feat .ic { width: 48px; height: 48px; margin: 0 auto 16px; border-radius: 50%; background: #fff; color: var(--green); display: grid; place-items: center; box-shadow: 0 4px 14px rgba(21,36,27,0.08); }
      .feat h3 { margin: 0 0 8px; font-family: var(--display-font); font-weight: 600; font-size: 1.08rem; }
      .feat p { margin: 0; color: var(--muted); font-size: 0.98rem; }

      /* Steps */
      .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
      @media (max-width: 720px) { .steps { grid-template-columns: 1fr; gap: 20px; } }
      .step { position: relative; text-align: center; padding: 0 12px; }
      .step .n { display: inline-grid; place-items: center; width: 66px; height: 66px; border-radius: 50%; border: 1.5px solid var(--green); color: var(--green); margin-bottom: 18px; position: relative; }
      .step .n svg { width: 26px; height: 26px; }
      .step .n b { position: absolute; top: -8px; right: -6px; width: 24px; height: 24px; border-radius: 50%; background: var(--gold); color: #1c1406; font-size: 12px; display: grid; place-items: center; font-weight: 700; }
      .step h3 { margin: 0 0 8px; font-family: var(--display-font); font-weight: 600; font-size: 1.16rem; }
      .step p { margin: 0; color: var(--muted); }

      /* Parallax stat band */
      .band { position: relative; overflow: hidden; color: #fff; text-align: center; background: var(--green-d); }
      .band .px-layer { position: absolute; inset: -12% 0; background-size: cover; background-position: center; will-change: transform; }
      .band .veil { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(18,37,26,0.72), rgba(18,37,26,0.82)); }
      .band .inner { position: relative; padding: clamp(70px, 11vw, 120px) 24px; }
      .band .stats { display: flex; justify-content: center; gap: 30px 64px; flex-wrap: wrap; margin-bottom: 34px; }
      .band .k { font-family: "Fraunces", Georgia, serif; font-size: var(--fs-stat); line-height: 1; }
      .band .l { margin-top: 10px; font-size: var(--fs-eyebrow); letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.72); }

      /* Service area */
      .area-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
      @media (max-width: 760px) { .area-wrap { grid-template-columns: 1fr; } }
      .pills { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 6px; }
      .pill { background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 9px 18px; font-weight: 600; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 8px; }
      .pill svg { width: 15px; height: 15px; color: var(--green); }
      .map { border: 1px solid var(--line); border-radius: 18px; overflow: hidden; aspect-ratio: 4 / 3; background: var(--tint); }
      .map iframe { width: 100%; height: 100%; border: 0; display: block; }

      /* Contact / CTA */
      .contact-card { background: var(--surface); border: 1px solid var(--line); border-radius: 24px; padding: clamp(30px, 5vw, 54px); display: grid; grid-template-columns: 1fr 1fr; gap: 44px; box-shadow: 0 24px 60px rgba(21, 36, 27, 0.08); }
      @media (max-width: 760px) { .contact-card { grid-template-columns: 1fr; gap: 30px; } }
      .contact-card h2 { margin: 12px 0 0; font-size: var(--fs-h2); }
      .contact-card .cc-copy p { color: var(--muted); margin: 16px 0 0; }
      .cc-info { margin-top: 26px; display: grid; gap: 14px; }
      .cc-info a { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; font-weight: 600; }
      .cc-info a svg { width: 18px; height: 18px; color: var(--green); }
      form.quote { display: grid; gap: 16px; }
      .field label { display: block; font-size: var(--fs-eyebrow); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 7px; }
      .field input, .field textarea { width: 100%; background: var(--bg); border: 1px solid var(--line); border-radius: 10px; padding: 13px 14px; font: inherit; color: var(--ink); }
      .field input:focus, .field textarea:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 3px rgba(31,82,54,0.12); }
      .field textarea { resize: vertical; min-height: 96px; }
      .req { color: var(--gold); }
      .opt { color: var(--muted); font-weight: 400; }
      .field .err { margin: 7px 0 0; color: #b23a20; font-size: var(--fs-eyebrow); }
      .field.invalid input, .field.invalid textarea { border-color: #b23a20; }
      .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; box-shadow: none; }
      .btn-primary:disabled:hover { background: var(--green); transform: none; }
      .form-note { margin: 4px 0 0; font-size: var(--fs-eyebrow); color: var(--muted); }
      .hp { position: absolute; left: -9999px; }

      /* Footer (dark, distinct from V1) */
      footer.site { background: var(--dark); color: var(--dark-fg); }
      .foot-grid { display: flex; justify-content: space-between; gap: 40px 64px; flex-wrap: wrap; padding-block: 60px 40px; }
      .foot-brand { max-width: 34ch; }
      .foot-brand .wordmark { color: #fff; }
      .foot-brand p { margin: 14px 0 0; color: var(--dark-muted); }
      .foot-col p.h { margin: 0 0 14px; font-size: var(--fs-eyebrow); letter-spacing: 0.14em; text-transform: uppercase; color: var(--dark-muted); font-weight: 700; }
      .foot-col a, .foot-col span { display: block; text-decoration: none; color: var(--dark-fg); margin-bottom: 10px; }
      .foot-col a:hover { color: #fff; }
      .foot-bar { display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap; padding-block: 20px 40px; border-top: 1px solid rgba(255,255,255,0.12); }
      .foot-bar small { color: var(--dark-muted); font-size: 13px; }

      /* Reveal */
      .reveal { opacity: 1; transform: none; }
      html.io-ready .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.7s ease, transform 0.7s ease; }
      html.io-ready .reveal.in { opacity: 1; transform: none; }
    </style>
  </head>

  <body>
    <a class="skip" href="#main">Skip to main content</a>

    <header class="site">
      <div class="wrap row">
        <a class="wordmark" href="#top">PNW <span>Arborist</span></a>
        <a class="btn btn-primary head-cta" href="#contact">Get a Free Quote</a>
      </div>
    </header>

    <main id="main">
      <!-- HERO -->
      <div id="top" class="hero" data-px="60">
        {heroImg && <div class="px-layer" style={`background-image:url(${heroImg})`}></div>}
        <div class="veil"></div>
        <div class="inner">
          <p class="eyebrow reveal">Certified arborists · {seo.city}, {seo.region}</p>
          <h1 class="display reveal">{c.heroHeadline}</h1>
          <p class="sub reveal">{c.heroSub}</p>
          <div class="cta reveal">
            <a class="btn btn-gold" href="#contact">Get a Free Quote <Icon name="arrow-right" /></a>
            <a class="btn btn-ghost" href={`tel:${tel}`}>Call {b.phone}</a>
          </div>
          <div class="trust reveal">
            <span><Icon name="star" /> <b>4.9</b> Google rating</span>
            <span><Icon name="badge-check" /> <b>200+</b> reviews</span>
            <span><Icon name="leaf" /> Free estimates</span>
          </div>
        </div>
      </div>

      <!-- SERVICES (cards) -->
      <section id="services">
        <div class="wrap">
          <div class="head-center reveal">
            <p class="eyebrow">What we do</p>
            <h2 class="display">Expert care for every tree on your property</h2>
            <p>From removals to fine pruning and honest health assessments — one careful, local team.</p>
          </div>
          <div class="cards">
            {
              client.services.map((s, i) => (
                <div class="card reveal">
                  <div class="ic"><Icon name={SERVICE_ICONS[i % SERVICE_ICONS.length]} /></div>
                  <h3>{s.title}</h3>
                  <p>{s.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- FEATURES -->
      <section class="features">
        <div class="wrap">
          <div class="head-center reveal">
            <p class="eyebrow">Why homeowners choose us</p>
            <h2 class="display">Reliable, tidy, and genuinely local</h2>
          </div>
          <div class="feat-grid">
            {
              FEATURES.map((f) => (
                <div class="feat reveal">
                  <div class="ic"><Icon name={f.icon} /></div>
                  <h3>{f.title}</h3>
                  <p>{f.text}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- STEPS -->
      <section>
        <div class="wrap">
          <div class="head-center reveal">
            <p class="eyebrow">How it works</p>
            <h2 class="display">Three simple steps</h2>
          </div>
          <div class="steps">
            {
              STEPS.map((s, i) => (
                <div class="step reveal">
                  <span class="n"><Icon name={s.icon} /><b>{i + 1}</b></span>
                  <h3>{s.title}</h3>
                  <p>{s.text}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- PARALLAX STAT BAND -->
      <div class="band" data-px="70">
        {bandImg && <div class="px-layer" style={`background-image:url(${bandImg})`}></div>}
        <div class="veil"></div>
        <div class="inner">
          <div class="stats">
            <div class="reveal"><div class="k">4.9★</div><div class="l">Google rating</div></div>
            <div class="reveal"><div class="k">200+</div><div class="l">Google reviews</div></div>
            <div class="reveal"><div class="k">Free</div><div class="l">On-site estimates</div></div>
          </div>
          <a class="btn btn-gold reveal" href={googleUrl} target="_blank" rel="noopener">Read the reviews on Google <Icon name="arrow-right" /></a>
        </div>
      </div>

      <!-- SERVICE AREA -->
      <section id="service-area">
        <div class="wrap area-wrap">
          <div class="reveal">
            <p class="eyebrow">Service area</p>
            <h2 class="display" style="font-size:var(--fs-h2); margin:14px 0 18px;">Serving Olympia & Thurston County</h2>
            <div class="pills">
              {b.serviceAreas.map((a) => (
                <span class="pill"><Icon name="map-pin" /> {a}</span>
              ))}
            </div>
          </div>
          <div class="map reveal">
            <iframe
              title={`Map of ${client.map.embedQuery}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src={`https://www.google.com/maps?q=${encodeURIComponent(client.map.embedQuery ?? `${seo.city}, ${seo.region}`)}&output=embed`}
            ></iframe>
          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <section id="contact">
        <div class="wrap">
          <div class="contact-card reveal">
            <div class="cc-copy">
              <p class="eyebrow">Get in touch</p>
              <h2 class="display">Get a Free Quote</h2>
              <p>{c.about}</p>
              <div class="cc-info">
                <a href={`tel:${tel}`}><Icon name="phone-call" /> {b.phone}</a>
                <a href={`mailto:${b.email}`}><Icon name="arrow-right" /> {b.email}</a>
              </div>
            </div>
            <form class="quote" action="https://api.web3forms.com/submit" method="POST">
              <input type="hidden" name="access_key" value={client.form.accessKey} />
              <input type="hidden" name="subject" value={`New quote request — ${b.name}`} />
              <input type="hidden" name="from_name" value={b.name} />
              <input type="hidden" name="redirect" value={thanksUrl} />
              <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <div class="field">
                <label for="name">Name <span class="req" aria-hidden="true">*</span></label>
                <input id="name" name="name" type="text" required autocomplete="name" aria-describedby="err-name" />
                <p class="err" id="err-name" hidden>Please enter your name.</p>
              </div>
              <div class="field">
                <label for="email">Email <span class="req" aria-hidden="true">*</span></label>
                <input id="email" name="email" type="email" required autocomplete="email" aria-describedby="err-email" />
                <p class="err" id="err-email" hidden>Please enter a valid email address.</p>
              </div>
              <div class="field">
                <label for="phone">Phone <span class="opt">(optional)</span></label>
                <input id="phone" name="phone" type="tel" autocomplete="tel" />
              </div>
              <div class="field">
                <label for="message">What do you need? <span class="opt">(optional)</span></label>
                <textarea id="message" name="message" placeholder="Tree removal, pruning, a health assessment…"></textarea>
              </div>
              <button class="btn btn-primary" type="submit" id="submitBtn">Submit</button>
              <p class="form-note">* Required. We'll reply within one business day.</p>
            </form>
          </div>
        </div>
      </section>
    </main>

    <footer class="site">
      <div class="wrap foot-grid">
        <div class="foot-brand">
          <a class="wordmark" href="#top">PNW <span>Arborist</span></a>
          <p>{b.name} — certified arborists serving {seo.city} and the surrounding Thurston County area.</p>
        </div>
        <div class="foot-col">
          <p class="h">Explore</p>
          <a href="#services">Services</a>
          <a href="#service-area">Service area</a>
          <a href="#contact">Get a quote</a>
        </div>
        <div class="foot-col">
          <p class="h">Contact</p>
          <a href={`tel:${tel}`}>{b.phone}</a>
          <a href={`mailto:${b.email}`}>{b.email}</a>
          <span>{b.serviceAreas.join(", ")}</span>
        </div>
      </div>
      <div class="wrap foot-bar">
        <small>© {b.name} · {seo.city}, {seo.region}</small>
        <small>Free, no-obligation estimates</small>
      </div>
    </footer>

    <PreviewControls variant="v2" defaultDisplay="satoshi" defaultBody="inter" />

    <script is:inline>
      // Lightweight parallax (reduced-motion safe).
      (function () {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var els = Array.prototype.slice.call(document.querySelectorAll("[data-px]"));
        if (!els.length) return;
        function upd() {
          var vh = window.innerHeight;
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            var layer = el.querySelector(".px-layer");
            if (!layer) continue;
            var r = el.getBoundingClientRect();
            var prog = (r.top + r.height / 2 - vh / 2) / vh;
            var amt = parseFloat(el.getAttribute("data-px")) || 40;
            layer.style.transform = "translate3d(0," + (prog * amt).toFixed(1) + "px,0)";
          }
        }
        var ticking = false;
        window.addEventListener("scroll", function () {
          if (!ticking) { requestAnimationFrame(function () { upd(); ticking = false; }); ticking = true; }
        }, { passive: true });
        window.addEventListener("resize", upd);
        upd();
      })();
    </script>

    <script is:inline>
      // Scroll reveal (armed only when html.io-ready).
      if (document.documentElement.classList.contains("io-ready")) {
        var io = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) { entries[i].target.classList.add("in"); io.unobserve(entries[i].target); }
          }
        }, { rootMargin: "0px 0px -8% 0px", threshold: 0.1 });
        document.querySelectorAll(".reveal").forEach(function (el) { io.observe(el); });
      }
    </script>

    <script is:inline>
      // Progressive form validation (mirrors V1).
      (function () {
        var f = document.querySelector("form.quote");
        if (!f) return;
        var name = f.querySelector("#name"), email = f.querySelector("#email"), btn = f.querySelector("#submitBtn");
        function emailOk(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
        function valid(inp) { if (inp === name) return name.value.trim().length > 0; if (inp === email) return emailOk(email.value.trim()); return true; }
        function mark(inp, show) { var fl = inp.closest(".field"); var er = fl.querySelector(".err"); fl.classList.toggle("invalid", show); if (er) er.hidden = !show; }
        function refresh() { btn.disabled = !(valid(name) && valid(email)); }
        [name, email].forEach(function (inp) {
          inp.addEventListener("input", function () { refresh(); if (inp.closest(".field").classList.contains("invalid")) mark(inp, !valid(inp)); });
          inp.addEventListener("blur", function () { mark(inp, !valid(inp)); });
        });
        f.addEventListener("submit", function (e) {
          var ok = true;
          [name, email].forEach(function (inp) { if (!valid(inp)) { mark(inp, true); ok = false; } });
          if (!ok) { e.preventDefault(); var first = f.querySelector(".field.invalid input"); if (first) first.focus(); }
        });
        refresh();
      })();
    </script>
  </body>
</html>
