---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

/**
 * Responsive image with LCP hygiene.
 *
 * Optimized path: when the photo lives in the app's `src/assets/photos/`, it is
 * processed by astro:assets — responsive `srcset`, modern formats, hashed URLs.
 * Verbatim path: anything else (e.g. files served from `public/`) renders as a
 * plain <img> with explicit dimensions so layout doesn't shift.
 *
 * The glob below is root-relative, so it resolves against the *app's* src dir
 * even though this component ships from the template package.
 */
interface Props {
  src: string;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  width?: number;
  height?: number;
  class?: string;
}

const {
  src,
  alt,
  widths = [400, 800, 1200, 1600],
  sizes = "100vw",
  loading = "lazy",
  fetchpriority = "auto",
  width,
  height,
  class: className,
} = Astro.props;

const assets = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/photos/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const basename = src.split("/").pop() ?? src;
const match = Object.entries(assets).find(([path]) => path.endsWith("/" + basename));
---

{
  match ? (
    <Image
      src={match[1].default}
      alt={alt}
      widths={widths}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
    />
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding={loading === "eager" ? "sync" : "async"}
      class={className}
    />
  )
}
