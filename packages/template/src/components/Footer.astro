---
import type { ClientConfig } from "@hirobius/schema";
import { telHref } from "../lib/theme.js";

interface Props {
  config: ClientConfig;
}

const { config } = Astro.props;
const { business, seo } = config;
const tel = telHref(business.phone);
const year = new Date().getFullYear();
---

<footer class="bg-fg text-on-primary/90">
  <div class="mx-auto grid max-w-6xl gap-8 px-5 py-12 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <p class="font-heading text-lg font-bold text-on-primary">{business.name}</p>
      <p class="mt-2 text-sm">Serving {seo.city}, {seo.region} and surrounding areas.</p>
    </div>
    <div class="text-sm">
      <p class="font-semibold text-on-primary">Contact</p>
      <p class="mt-2"><a class="inline-block py-1.5 underline" href={tel}>{business.phone}</a></p>
      <p><a class="inline-block py-1.5 underline" href={`mailto:${business.email}`}>{business.email}</a></p>
    </div>
    <div class="text-sm">
      <p class="font-semibold text-on-primary">Hours</p>
      {business.hours.map((h) => <p class="mt-1">{h.days}: {h.hours}</p>)}
    </div>
  </div>
  <div class="border-t border-on-primary/15">
    <p class="mx-auto max-w-6xl px-5 py-4 text-xs text-on-primary/60">
      © {year} {business.name}. All rights reserved.
    </p>
  </div>
</footer>
