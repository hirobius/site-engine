---
// Hero dispatcher — renders the variant selected by
// `config.layout.sections.hero.variant`. The map is checked against the
// schema's closed enum (`satisfies`), so adding a SECTION_VARIANTS value
// without a component here fails `astro check`.
import type { ClientConfig, SECTION_VARIANTS } from "@hirobius/schema";
import Classic from "./hero/classic.astro";
import Video from "./hero/video.astro";

interface Props {
  config: ClientConfig;
}

const { config } = Astro.props;

const VARIANTS = {
  classic: Classic,
  video: Video,
} satisfies Record<(typeof SECTION_VARIANTS)["hero"][number], unknown>;

const Variant = VARIANTS[config.layout.sections.hero.variant];
---

<Variant config={config} />
