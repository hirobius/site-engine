---
// Reviews dispatcher — renders the variant selected by
// `config.layout.sections.reviews.variant`. The map is checked against the
// schema's closed enum (`satisfies`), so adding a SECTION_VARIANTS value
// without a component here fails `astro check`.
import type { ClientConfig, SECTION_VARIANTS } from "@hirobius/schema";
import Cards from "./reviews/cards.astro";

interface Props {
  config: ClientConfig;
}

const { config } = Astro.props;

const VARIANTS = {
  cards: Cards,
} satisfies Record<(typeof SECTION_VARIANTS)["reviews"][number], unknown>;

const Variant = VARIANTS[config.layout.sections.reviews.variant];
---

<Variant config={config} />
