---
/** Shared section wrapper: consistent rhythm, optional muted surface + heading. */
interface Props {
  id: string;
  title?: string;
  subtitle?: string;
  muted?: boolean;
  class?: string;
}

const { id, title, subtitle, muted = false, class: className } = Astro.props;
---

<section
  id={id}
  class:list={["scroll-mt-16 py-16 sm:py-20", muted && "bg-muted", className]}
>
  <div class="mx-auto max-w-6xl px-5">
    {
      (title || subtitle) && (
        <header class="mb-10 max-w-2xl">
          {title && <h2 class="font-heading text-3xl font-bold sm:text-4xl">{title}</h2>}
          {subtitle && <p class="mt-3 text-lg text-fg/70">{subtitle}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>
