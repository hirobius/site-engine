---
import type { ClientConfig } from "@hirobius/schema";
import { brandStyle } from "../lib/theme.js";
import BaseHead from "./BaseHead.astro";
import Motion from "./Motion.astro";

/**
 * HTML document shell. The per-client palette is applied as an inline style on
 * <html> so it always wins the cascade over the stylesheet defaults.
 *
 * The consuming app imports its global.css (Tailwind entry) in the page that
 * renders this — the CSS is injected as a side effect regardless of where the
 * <html> tag is authored.
 */
interface Props {
  config: ClientConfig;
  /** Force noindex regardless of the NOINDEX env var (e.g. the /thanks page). */
  noindex?: boolean;
}

const { config, noindex = false } = Astro.props;
const style = brandStyle(config);
const motion = config.brand.motion;
---

<!doctype html>
<html lang="en" style={style} data-motion={motion}>
  <head>
    <BaseHead config={config} noindex={noindex} />
    {
      /* Arm the reveal/rise CSS before first paint (no flash), but only for
         visitors who haven't asked for reduced motion. No motion class => the
         `.reveal`/`.rise` base state stays fully visible (no-JS-safe). #22 */
      motion !== "none" && (
        <script is:inline>
          if (!matchMedia("(prefers-reduced-motion: reduce)").matches)
            document.documentElement.classList.add("motion-ready");
        </script>
      )
    }
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main-content"
      class="sr-only focus-visible:not-sr-only focus-visible:absolute focus-visible:left-4 focus-visible:top-4 focus-visible:z-50 focus-visible:rounded-theme focus-visible:bg-primary focus-visible:px-4 focus-visible:py-2 focus-visible:font-semibold focus-visible:text-on-primary"
    >
      Skip to main content
    </a>
    <slot />
    {motion !== "none" && <Motion motion={motion} />}
  </body>
</html>
