---
import type { ClientConfig } from "@hirobius/schema";
import { telHref } from "../lib/theme.js";

interface Props {
  config: ClientConfig;
}

const { config } = Astro.props;
const { business, copy } = config;
const tel = telHref(business.phone);
---

{/* Mobile-only sticky call/quote bar. Hidden on >= sm where the header CTAs
    are visible. Zero JS. */}
<div
  class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 gap-px border-t border-fg/10 bg-bg/95 backdrop-blur sm:hidden"
  style="padding-bottom: env(safe-area-inset-bottom);"
>
  <a
    href={tel}
    class="flex items-center justify-center gap-2 py-3 font-semibold text-primary"
  >
    <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
      <path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1l-2.1 2.2Z" />
    </svg>
    Call Now
  </a>
  <a
    href="#contact"
    class="flex items-center justify-center bg-primary py-3 font-semibold text-on-primary"
  >
    {copy.ctaLabel}
  </a>
</div>

{/* Spacer so the bar never covers footer content on mobile. */}
<div class="h-14 sm:hidden" aria-hidden="true"></div>
