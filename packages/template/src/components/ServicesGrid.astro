---
// Services dispatcher — renders the variant selected by
// `config.layout.sections.services.variant`. The map is checked against the
// schema's closed enum (`satisfies`), so adding a SECTION_VARIANTS value
// without a component here fails `astro check`.
import type { ClientConfig, SECTION_VARIANTS } from "@hirobius/schema";
import Grid from "./services/grid.astro";

interface Props {
  config: ClientConfig;
}

const { config } = Astro.props;

const VARIANTS = {
  grid: Grid,
} satisfies Record<(typeof SECTION_VARIANTS)["services"][number], unknown>;

const Variant = VARIANTS[config.layout.sections.services.variant];
---

<Variant config={config} />
